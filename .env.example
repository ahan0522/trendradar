# Supabase / PostgreSQL
# 1. 在 Supabase 建立 project
# 2. 到 SQL Editor 執行 supabase/schema.sql
# 3. 將 Project Settings > API 裡的 URL 與 service_role key 放到 .env.local
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: protect /api/sync
SYNC_SECRET=

CRON_SECRET=replace-with-a-random-secret

# Optional: protect /api/admin/* routes. If empty, CRON_SECRET is used.
ADMIN_SECRET=

# Optional AI summaries.
# Leave AI_SUMMARY_PROVIDER empty to keep the free rule-based summarizer.
# Set AI_SUMMARY_PROVIDER=openai and provide OPENAI_API_KEY to enable API calls.
AI_SUMMARY_PROVIDER=
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-5-nano
